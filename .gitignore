# =============================================================================
# DropClicker — .gitignore
# =============================================================================

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Environment Variables (NEVER commit these) ───────────────────────────────
.env
.env.local
.env.development
.env.production
.env.test

# ─── TypeScript Build Output ──────────────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Runtime / OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Uploads (local temp files) ───────────────────────────────────────────────
uploads/
temp/

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Deployment ───────────────────────────────────────────────────────────────
.vercel
